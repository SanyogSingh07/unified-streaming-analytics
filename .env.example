# ─── Application ─────────────────────────────────────────────────────────────
# FastAPI backend port
PORT=8000

# Frontend development port
FRONTEND_PORT=3000

# Environment: development | production
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite path (relative to backend directory)
DATABASE_URL=sqlite:///./netflix_analytics.db

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
# Google Gemini API key for AI-powered search analysis
GEMINI_API_KEY=your_gemini_api_key_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── ML Model ─────────────────────────────────────────────────────────────────
# Path to the saved Random Forest model (relative to project root)
MODEL_PATH=model/models/random_forest.pkl

# Path to evaluation results
EVALUATION_PATH=model/evaluation/ml_results.json

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=model/logs

# ─── Docker ───────────────────────────────────────────────────────────────────
# Docker Compose project name
COMPOSE_PROJECT_NAME=netflix-analytics

# ─── Security (Production Only) ───────────────────────────────────────────────
# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
